CREATE PROCEDURE `UPDATE_AGREEMENT_STATUS`()
BEGIN
    DECLARE LS_DESCRIPTION VARCHAR(200);

    -- Temp table to hold the IDs
    CREATE TEMPORARY TABLE IF NOT EXISTS TEMP_UPDATED_AGREEMENT_IDS (
        AGREEMENT_REQUEST_ID INT
    );
    TRUNCATE TABLE TEMP_UPDATED_AGREEMENT_IDS;

    -- Step 1: Capture the IDs BEFORE updating
    INSERT INTO TEMP_UPDATED_AGREEMENT_IDS (AGREEMENT_REQUEST_ID)
    SELECT AH.AGREEMENT_REQUEST_ID
    FROM AGREEMENT_HEADER AH
    INNER JOIN AGREEMENT_CATEGORY AC ON AC.CATEGORY_CODE = AH.CATEGORY_CODE
    WHERE
        (AC.CATEGORY_CODE = '1'        AND AH.AGREEMENT_STATUS_CODE = 15)
        OR
        (AC.CATEGORY_CODE IN ('2','3') AND AH.AGREEMENT_STATUS_CODE = 12);

    -- Step 2: Perform the UPDATE first
    UPDATE AGREEMENT_HEADER AH
    INNER JOIN AGREEMENT_CATEGORY AC ON AC.CATEGORY_CODE = AH.CATEGORY_CODE
    SET
        AH.AGREEMENT_STATUS_CODE = 4,
        AH.UPDATE_TIMESTAMP = NOW()
    WHERE
        (AC.CATEGORY_CODE = '1' AND AH.AGREEMENT_STATUS_CODE = 15)
        OR
        (AC.CATEGORY_CODE IN ('2','3') AND AH.AGREEMENT_STATUS_CODE = 12);

    -- Step 3: Log ONLY if rows were actually updated
    IF ROW_COUNT() > 0 THEN

        SELECT DESCRIPTION INTO LS_DESCRIPTION
        FROM AGREEMENT_STATUS
        WHERE AGREEMENT_STATUS_CODE = '4';

        INSERT INTO AGREEMENT_ACTION_LOG
        (
            ACTION_TYPE_CODE,
            DESCRIPTION,
            UPDATE_TIMESTAMP,
            UPDATE_USER,
            AGREEMENT_REQUEST_ID
        )
        SELECT
            54,
            CONCAT('Agreement action has been ', LS_DESCRIPTION),
            NOW(),
            'SCHEDULER',
            T.AGREEMENT_REQUEST_ID
        FROM TEMP_UPDATED_AGREEMENT_IDS T
        -- Re-join to confirm the status was actually flipped to 4
        INNER JOIN AGREEMENT_HEADER AH ON AH.AGREEMENT_REQUEST_ID = T.AGREEMENT_REQUEST_ID
        WHERE AH.AGREEMENT_STATUS_CODE = 4;

    END IF;

    -- Step 4: Return updated IDs and clean up
    SELECT AGREEMENT_REQUEST_ID FROM TEMP_UPDATED_AGREEMENT_IDS;
    DROP TEMPORARY TABLE IF EXISTS TEMP_UPDATED_AGREEMENT_IDS;

END
